{
  "name": "tstack",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "turbo format",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "seed": "bun run --cwd apps/api seed",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bunx biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "turbo": "^2.8.13"
  },
  "dependencies": {}
}
