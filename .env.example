# ============================================
# tstack Starter Kit — Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# --- App ---
PORT=8000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/tstack

# --- JWT ---
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
PASSWORD_RESET_TTL=15m

# --- Superadmin (seeded on first run) ---
SUPERADMIN_EMAIL=admin@tstack.app
SUPERADMIN_PASSWORD=replace-with-strong-password
SUPERADMIN_FIRST_NAME=Super
SUPERADMIN_LAST_NAME=Admin

# --- Email (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=noreply@tstack.app

# --- Storage (S3 + CloudFront, optional) ---
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET_NAME=
# CDN_BASE_URL=

# --- Redis (for BullMQ queues, optional) ---
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# --- Web Frontend ---
VITE_API_URL=http://localhost:8000/api
